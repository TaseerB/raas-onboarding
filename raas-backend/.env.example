# raas-backend environment variables
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# The .env file is gitignored — never commit it.

# PostgreSQL
DB_NAME=raas
DB_USER=raas
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Application database connection (used by Spring Boot)
DB_HOST=localhost
DB_PORT=5432

# JWT issuer URI (e.g. your Keycloak or Spring Authorization Server)
JWT_ISSUER_URI=http://localhost:9000
